  "steps": [
    { "order": 1, "text": "第一步：確認意外發生於 6 個月內，並準備意外及傷勢證明。" },
    { "order": 2, "text": "第二步：填寫 TAVA 申請表（社署網上初步申請表或紙本表格）。" },
    { "order": 3, "text": "第三步：連同醫生／中醫證明及意外證明遞交社會福利署。" },
    { "order": 4, "text": "第四步：接受社署審核。" },
    { "order": 5, "text": "第五步：批核後領取援助金。" }
