# Supabase project URL（喺 Supabase Dashboard → Project Settings → API 取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon public key（可以公開，受 RLS 保護）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key（只限伺服器使用，切勿外洩）
# 用於 admin / seed 等需要繞過 RLS 的操作
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
